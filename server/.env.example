# ---- Server ----
PORT=4000
# Origin van de frontend die de API mag aanroepen (CORS). Meerdere: komma-gescheiden.
CORS_ORIGIN=http://localhost:8765,http://localhost:8080
# Geheime sleutel voor sessie-tokens. Genereer met: openssl rand -hex 32
SESSION_SECRET=verander-mij-naar-een-lange-random-string
# Zet op true achter HTTPS (productie); laat false voor lokaal http.
COOKIE_SECURE=false

# ---- MySQL (server van Johan) ----
# Scenario 1: API draait OP Johan's server  -> DB_HOST=localhost
# Scenario 2: API lokaal, DB via SSH-tunnel -> DB_HOST=127.0.0.1 (zie README)
# Scenario 3: directe remote MySQL          -> DB_HOST=<server-ip> + DB_SSL=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=meetingrooms
DB_PASSWORD=
DB_NAME=meetingrooms_h20
# Zet op true als de remote MySQL TLS vereist
DB_SSL=false
